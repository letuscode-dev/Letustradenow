# Required: Deriv app id — drives OAuth login/sign-up and WebSocket connections.
# Register at https://developers.deriv.com/dashboard/
NEXT_PUBLIC_DERIV_APP_ID=33DhZYBM70f2KzCnor1IY

# Optional: environment + affiliate attribution.
# Use `production` for live Deriv endpoints; `preview` or `staging` for staging.
NEXT_PUBLIC_DERIV_ENV=production
NEXT_PUBLIC_DERIV_REFERRAL_LINK=

# Optional: partner app name shown in the header and browser tab.
# Falls back to brand.config.json platform.name when unset.
NEXT_PUBLIC_DERIV_APP_NAME=Letustradenow

# Optional: Google Drive integration (leave blank to disable).
# Requires Google Picker API + Drive API credentials.
GD_CLIENT_ID=
GD_APP_ID=
GD_API_KEY=
